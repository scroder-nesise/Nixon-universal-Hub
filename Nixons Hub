-- helper: safe loadstring with notify feedback
local function safeLoad(url, label)
    local ok, err = pcall(function()
        loadstring(game:HttpGet(url, true))()
    end)
    if ok then
        Rayfield:Notify({Title="Scripts", Content=label.." loaded!", Duration=3})
    else
        Rayfield:Notify({Title="Scripts Error", Content=label.." failed: "..tostring(err), Duration=5})
    end
end

