-- ================================================
--  Reach Extender
--  Scales your equipped tool's handle so melee
--  hits register from much farther away.
-- ================================================
CombatTab:CreateSection("Reach Extender")

local reachSize   = 10
local reachConn   = nil
local originalReach = {}

local function applyReach(enabled)
    local tool = char and char:FindFirstChildOfClass("Tool")
    if not tool then return end
    local handle = tool:FindFirstChild("Handle")
    if not handle then return end
    if enabled then
        if not originalReach.size then
            originalReach.size = handle.Size
        end
        handle.Size = Vector3.new(reachSize, reachSize, reachSize)
        handle.Transparency = 0.8
    else
        if originalReach.size then
            handle.Size         = originalReach.size
            handle.Transparency = 0
            originalReach.size  = nil
        end
    end
end

CombatTab:CreateToggle({
    Name         = "Reach Extender",
    CurrentValue = false,
    Flag         = "ReachExtender",
    Callback     = function(val)
        if val then
            applyReach(true)
            -- Re-apply whenever a new tool is equipped
            reachConn = char.ChildAdded:Connect(function(c)
                if c:IsA("Tool") then
                    task.wait(0.1)
                    applyReach(true)
                end
            end)
            Rayfield:Notify({Title="Combat", Content="Reach Extender ON", Duration=2})
        else
            applyReach(false)
            if reachConn then reachConn:Disconnect() reachConn = nil end
            Rayfield:Notify({Title="Combat", Content="Reach Extender OFF", Duration=2})
        end
    end,
})

CombatTab:CreateSlider({
    Name         = "Reach Size",
    Range        = {5, 80},
    Increment    = 1,
    Suffix       = "studs",
    CurrentValue = 10,
    Flag         = "ReachSize",
    Callback     = function(val)
        reachSize = val
        if char and char:FindFirstChildOfClass("Tool") then applyReach(true) end
    end,
})

