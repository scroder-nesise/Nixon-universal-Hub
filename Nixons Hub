VisualTab:CreateSection("World Effects")

-- Invert Colors via ColorCorrectionEffect + ScreenGui overlay
-- TintColor MULTIPLIES color values, so (0,0,0) = pure black (the old bug).
-- We keep TintColor white and use Brightness/Contrast/Saturation instead.
local invertEffect = Instance.new("ColorCorrectionEffect")
invertEffect.Name      = "NixonInvert"
invertEffect.Enabled   = false
invertEffect.Parent    = Lighting

-- Overlay frame to push whites toward dark (helps the inversion look)
local invertGui   = Instance.new("ScreenGui")
invertGui.Name    = "NixonInvertGui"
invertGui.ResetOnSpawn = false
invertGui.Enabled = false
invertGui.Parent  = game:GetService("CoreGui")
local invertFrame = Instance.new("Frame", invertGui)
invertFrame.Size  = UDim2.new(1, 0, 1, 0)
invertFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
invertFrame.BackgroundTransparency = 0.85
invertFrame.BorderSizePixel = 0

VisualTab:CreateToggle({
    Name         = "Invert Colors",
    CurrentValue = false,
    Flag         = "InvertColors",
    Callback     = function(val)
        invertEffect.Enabled    = val
        invertEffect.TintColor  = Color3.fromRGB(255, 255, 255) -- NEVER set to black
        invertEffect.Brightness  = val and -0.45 or 0
        invertEffect.Contrast    = val and -0.6  or 0
        invertEffect.Saturation  = val and -1    or 0
        -- Lighting shifts to make darks lighter and brights darker
        if val then
            Lighting.Brightness        = 3
            Lighting.GlobalShadows     = false
            Lighting.Ambient           = Color3.fromRGB(200, 200, 200)
            Lighting.OutdoorAmbient    = Color3.fromRGB(200, 200, 200)
        else
            Lighting.Brightness        = 1
            Lighting.GlobalShadows     = true
            Lighting.Ambient           = Color3.fromRGB(70, 70, 70)
            Lighting.OutdoorAmbient    = Color3.fromRGB(128, 128, 128)
        end
        invertGui.Enabled = val
        Rayfield:Notify({Title="Visual", Content= val and "Invert Colors ON" or "Invert Colors OFF", Duration=2})
    end,
})

-- Rainbow Sky
local rainbowSkyConn = nil
local rainbowHue     = 0

VisualTab:CreateToggle({
    Name         = "Rainbow Sky",
    CurrentValue = false,
    Flag         = "RainbowSky",
    Callback     = function(val)
        if val then
            -- Remove any existing sky first
            local old = Lighting:FindFirstChildOfClass("Sky")
            if old then old:Destroy() end
            local sky = Instance.new("Sky", Lighting)
            sky.Name  = "NixonRainbowSky"
            rainbowSkyConn = RunService.Heartbeat:Connect(function(dt)
                rainbowHue = (rainbowHue + dt * 0.05) % 1
                local col  = Color3.fromHSV(rainbowHue, 0.8, 1)
                Lighting.Ambient    = col
                Lighting.OutdoorAmbient = col
                Lighting.FogColor   = col
            end)
            Rayfield:Notify({Title="Visual", Content="Rainbow Sky ON", Duration=2})
        else
            if rainbowSkyConn then rainbowSkyConn:Disconnect() rainbowSkyConn = nil end
            local s = Lighting:FindFirstChild("NixonRainbowSky")
            if s then s:Destroy() end
            Lighting.Ambient        = Color3.fromRGB(70,  70,  70)
            Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
            Lighting.FogColor       = Color3.fromRGB(192, 192, 192)
            Rayfield:Notify({Title="Visual", Content="Rainbow Sky OFF", Duration=2})
        end
    end,
})

