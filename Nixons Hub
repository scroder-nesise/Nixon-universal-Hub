    l.Transparency = 1
    l.Visible      = true
    table.insert(crosshairParts, l)
    return l
end

local function newCircle(x, y, r, filled)
    local c        = Drawing.new("Circle")
    c.Position     = Vector2.new(x, y)
    c.Radius       = r
    c.Color        = crosshairColor
    c.Thickness    = crosshairThick
    c.Filled       = filled or false
    c.Transparency = 1
    c.Visible      = true
    table.insert(crosshairParts, c)
    return c
end

local function newQuad(ax,ay, bx,by, cx,cy, dx,dy)
    local q        = Drawing.new("Quad")
    q.PointA       = Vector2.new(ax, ay)
    q.PointB       = Vector2.new(bx, by)
    q.PointC       = Vector2.new(cx, cy)
    q.PointD       = Vector2.new(dx, dy)
    q.Color        = crosshairColor
    q.Thickness    = crosshairThick
    q.Filled       = false
    q.Transparency = 1
    q.Visible      = true
    table.insert(crosshairParts, q)
    return q
end

local function drawCrosshair()
    clearCrosshair()
    if not crosshairEnabled then return end
    local vp = workspace.CurrentCamera.ViewportSize
    local cx = vp.X / 2
    local cy = vp.Y / 2
    local s  = crosshairSize
    local g  = 4   -- center gap

    if crosshairStyle == "Dot" then
        -- 1. Dot — filled circle in center
        newCircle(cx, cy, 3, true)

    elseif crosshairStyle == "Cross" then
        -- 2. Cross (+) — 4 lines with gap
        newLine(cx - s, cy,   cx - g, cy  )   -- left
        newLine(cx + g, cy,   cx + s, cy  )   -- right
        newLine(cx,     cy-s, cx,     cy-g)   -- top
        newLine(cx,     cy+g, cx,     cy+s)   -- bottom

    elseif crosshairStyle == "X" then
        -- 3. X — diagonal lines with gap
        newLine(cx-s, cy-s, cx-g, cy-g)
        newLine(cx+g, cy+g, cx+s, cy+s)
        newLine(cx+s, cy-s, cx+g, cy-g)
        newLine(cx-g, cy+g, cx-s, cy+s)

    elseif crosshairStyle == "Circle" then
        -- 4. Circle — open ring
        newCircle(cx, cy, s, false)

    elseif crosshairStyle == "Square" then
        -- 5. Square — open box
        newQuad(cx-s, cy-s,  cx+s, cy-s,  cx+s, cy+s,  cx-s, cy+s)

    elseif crosshairStyle == "Sniper" then
        -- 6. Sniper — long thin lines with large gap
        local sg = s * 1.5
        newLine(cx - s*2, cy, cx - sg, cy)
        newLine(cx + sg,  cy, cx + s*2, cy)
        newLine(cx, cy - s*2, cx, cy - sg)
        newLine(cx, cy + sg,  cx, cy + s*2)
        newCircle(cx, cy, 2, true)   -- tiny center dot
    end
end

-- Redraw on every frame so it follows screen center
local crosshairConn = nil

local function startCrosshairLoop()
    if crosshairConn then crosshairConn:Disconnect() end
    crosshairConn = RunService.Heartbeat:Connect(function()
        if crosshairEnabled then drawCrosshair() end
    end)
end

