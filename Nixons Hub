-- >> ESP
VisualTab:CreateSection("ESP")

local espEnabled = false
local chamEnabled = false
local espFolder  = Instance.new("Folder")
espFolder.Name   = "NixonESP"
espFolder.Parent = game:GetService("CoreGui")

local function makeHighlight(player, fillCol, outlineCol, fillAlpha, outlineAlpha)
    if player == lp then return end
    local function build()
        local c = player.Character
        if not c then return end
        local old = espFolder:FindFirstChild(player.Name)
        if old then old:Destroy() end
        local hl                   = Instance.new("Highlight")
        hl.Name                    = player.Name
        hl.Adornee                 = c
        hl.FillColor               = fillCol    or Color3.fromRGB(255, 50, 50)
        hl.OutlineColor            = outlineCol or Color3.fromRGB(255, 255, 255)
        hl.FillTransparency        = fillAlpha    ~= nil and fillAlpha    or 0.5
        hl.OutlineTransparency     = outlineAlpha ~= nil and outlineAlpha or 0
        hl.DepthMode               = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent                  = espFolder
    end
    build()
    player.CharacterAdded:Connect(function()
        if espEnabled or chamEnabled then build() end
    end)
end

VisualTab:CreateToggle({
    Name         = "Player ESP",
    CurrentValue = false,
    Flag         = "PlayerESP",
