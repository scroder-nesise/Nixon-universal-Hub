PlayerTab:CreateDropdown({
    Name           = "Select Animation",
    Options        = (function()
        local list = {}
        for k in pairs(r15Animations) do table.insert(list, k) end
        table.sort(list)
        return list
    end)(),
    CurrentOption  = {"Idle"},
    MultipleOptions = false,
    Flag           = "R15AnimPick",
    Callback       = function(val)
        selectedAnim = type(val) == "table" and val[1] or val
