-- >> Teleport to Player
PlayerTab:CreateSection("Teleport to Player")

local selectedTarget = "None"

-- build a refreshed player list every time the button is pressed
PlayerTab:CreateButton({
    Name     = "Refresh Player List",
    Callback = function()
        local names = {}
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= lp then table.insert(names, p.Name) end
        end
        local display = #names > 0 and table.concat(names, ", ") or "No other players"
        Rayfield:Notify({Title="Player List", Content=display, Duration=6})
    end,
})

PlayerTab:CreateInput({
    Name        = "Type Player Name",
    PlaceholderText = "Enter exact username...",
    RemoveTextAfterFocusLost = false,
    Flag        = "TeleportTargetInput",
    Callback    = function(val)
        selectedTarget = val
    end,
})

PlayerTab:CreateButton({
    Name     = "Teleport to Player",
    Callback = function()
        if selectedTarget == "" or selectedTarget == "None" then
            Rayfield:Notify({Title="Player", Content="Type a player name first!", Duration=2})
            return
        end
        local target = Players:FindFirstChild(selectedTarget)
        if target and target.Character then
            local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
            local myRoot = char:FindFirstChild("HumanoidRootPart")
            if tRoot and myRoot then
                myRoot.CFrame = tRoot.CFrame + Vector3.new(3, 0, 0)
                Rayfield:Notify({Title="Player", Content="Teleported to "..selectedTarget, Duration=2})
            end
        else
            Rayfield:Notify({Title="Player", Content="Player '"..selectedTarget.."' not found.", Duration=3})
        end
    end,
})

