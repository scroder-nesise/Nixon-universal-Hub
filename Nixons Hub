-- ================================================
--  Shared combat state & helpers
-- ================================================
local combatEnabled = {
    silentAim  = false,
    aimbot     = false,
    hitbox     = false,
}

local aimbotFOV       = 150
local aimbotSmoothing = 0.15
local hitboxSize      = 10
local aimbotConn      = nil
local originalSizes   = {} -- stores original hitbox sizes

-- Returns the nearest enemy player's HumanoidRootPart within FOV
local function getNearestTarget()
    local cam    = workspace.CurrentCamera
    local origin = cam.CFrame.Position
    local best, bestDist = nil, math.huge

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            local h    = p.Character:FindFirstChildOfClass("Humanoid")
            if root and h and h.Health > 0 then
                -- Check screen FOV
                local screenPos, onScreen = cam:WorldToViewportPoint(root.Position)
                if onScreen then
                    local center = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
                    local dist2D = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if dist2D < aimbotFOV and dist2D < bestDist then
                        bestDist = dist2D
                        best     = root
                    end
                end
            end
        end
    end
    return best
end

-- ================================================
--  Silent Aim
--  Hooks FindPartOnRayWithIgnoreList / Raycast so
--  projectiles register on the nearest target.
-- ================================================
CombatTab:CreateSection("Silent Aim")

CombatTab:CreateToggle({
    Name         = "Silent Aim",
    CurrentValue = false,
    Flag         = "SilentAim",
    Callback     = function(val)
        combatEnabled.silentAim = val
        if val then
            -- Hook the camera's CFrame so rays resolve toward target
            local oldIndex = getrawmetatable(game).__index
            local oldNamecall = getrawmetatable(game).__namecall

            -- Use gethook/sethook alternative: wrap WorldRoot:Raycast
            local mt = getrawmetatable(workspace)
            setreadonly(mt, false)
            local oldRaycast = mt.__index and mt.__index.Raycast
            -- Fallback: hook via __namecall
            local _nc = oldNamecall
            setrawmetatable(game, getmetatable(game)) -- keep ref
            rawset(getrawmetatable(game), "__namecall", newcclosure(function(self, ...)
                local method = getnamecallmethod()
                local args   = {...}
                if combatEnabled.silentAim and method == "FindPartOnRayWithIgnoreList" then
                    local target = getNearestTarget()
                    if target then
                        local ray    = args[1]
                        local newRay = Ray.new(ray.Origin, (target.Position - ray.Origin).Unit * ray.Direction.Magnitude)
                        args[1]      = newRay
                    end
                end
                return _nc(self, table.unpack(args))
            end))
            setreadonly(mt, true)
            Rayfield:Notify({Title="Combat", Content="Silent Aim ON", Duration=2})
        else
            Rayfield:Notify({Title="Combat", Content="Silent Aim OFF", Duration=2})
        end
    end,
})

