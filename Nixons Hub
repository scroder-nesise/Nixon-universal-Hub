-- Patch getNearestTarget to respect team check
local _origGetNearest = getNearestTarget
getNearestTarget = function()
    if not _G.CombatTeamCheck then return _origGetNearest() end
    local cam    = workspace.CurrentCamera
    local best, bestDist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Team ~= lp.Team and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            local h    = p.Character:FindFirstChildOfClass("Humanoid")
            if root and h and h.Health > 0 then
                local screenPos, onScreen = cam:WorldToViewportPoint(root.Position)
                if onScreen then
                    local center = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
                    local dist2D = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if dist2D < aimbotFOV and dist2D < bestDist then
                        bestDist = dist2D
                        best     = root
                    end
                end
            end
        end
    end
    return best
end

