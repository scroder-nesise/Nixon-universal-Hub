                makeHighlight(p, Color3.fromRGB(255,50,50), Color3.fromRGB(255,255,255), 0.5, 0)
            end
            Players.PlayerAdded:Connect(function(p)
                if espEnabled then
                    makeHighlight(p, Color3.fromRGB(255,50,50), Color3.fromRGB(255,255,255), 0.5, 0)
                end
