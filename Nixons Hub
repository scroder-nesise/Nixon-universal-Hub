-- ================================================
--  Hitbox Expander
--  Scales every enemy's HumanoidRootPart up so
--  shots register much more easily.
-- ================================================
CombatTab:CreateSection("Hitbox Expander")

local function applyHitboxes(enabled)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root then
                if enabled then
                    -- Save original if not saved yet
                    if not originalSizes[p.Name] then
                        originalSizes[p.Name] = root.Size
                    end
                    root.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                else
                    -- Restore
                    if originalSizes[p.Name] then
                        root.Size = originalSizes[p.Name]
                        originalSizes[p.Name] = nil
                    end
                end
            end
        end
    end
end

CombatTab:CreateToggle({
    Name         = "Hitbox Expander",
    CurrentValue = false,
    Flag         = "HitboxExpander",
    Callback     = function(val)
        combatEnabled.hitbox = val
        applyHitboxes(val)
        if val then
            -- Keep applying on new characters
            Players.PlayerAdded:Connect(function(p)
                p.CharacterAdded:Connect(function(c)
                    if not combatEnabled.hitbox then return end
                    local root = c:WaitForChild("HumanoidRootPart", 5)
                    if root then
                        originalSizes[p.Name] = root.Size
                        root.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                    end
                end)
            end)
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= lp then
                    p.CharacterAdded:Connect(function(c)
                        if not combatEnabled.hitbox then return end
                        local root = c:WaitForChild("HumanoidRootPart", 5)
                        if root then
                            originalSizes[p.Name] = root.Size
                            root.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                        end
                    end)
                end
            end
            Rayfield:Notify({Title="Combat", Content="Hitbox Expander ON", Duration=2})
        else
            applyHitboxes(false)
            Rayfield:Notify({Title="Combat", Content="Hitbox Expander OFF  (sizes restored)", Duration=2})
        end
    end,
})

CombatTab:CreateSlider({
    Name         = "Hitbox Size",
    Range        = {4, 60},
    Increment    = 1,
    Suffix       = "studs",
    CurrentValue = 10,
    Flag         = "HitboxSize",
    Callback     = function(val)
